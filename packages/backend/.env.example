# PPBears CS SaaS - Backend Environment Variables
# Copy to .env and fill in actual values

# Server
PORT=8080
HOST=0.0.0.0
LOG_LEVEL=info

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# JWT (Admin Panel Auth)
JWT_SECRET=change-me-to-a-strong-random-string
JWT_EXPIRES_IN=24h

# Admin Elevated Session
ADMIN_SESSION_DURATION_MINUTES=10
ADMIN_UNLOCK_PASSWORD=change-me-secure-password

# Message Gate (milliseconds)
MESSAGE_GATE_WINDOW_MS=8000

# Live Agent (hours)
LIVE_AGENT_DURATION_HOURS=24

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# LINE (per-tenant, stored in DB, but default for dev)
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Gemini
GEMINI_API_KEY=your-gemini-api-key

# WooCommerce
WOO_BASE_URL=https://ppbears.com
WOO_CONSUMER_KEY=your-woo-consumer-key
WOO_CONSUMER_SECRET=your-woo-consumer-secret
